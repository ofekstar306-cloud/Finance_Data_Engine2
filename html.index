<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>מערכת איחוד נתוני מניות | דור הבא</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Assistant:wght@300;400;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Assistant', sans-serif; background-color: #050810; }
        .cyber-panel { background-color: rgba(13, 20, 38, 0.95); border: 1px solid rgba(0, 195, 255, 0.15); box-shadow: 0 0 25px rgba(0, 195, 255, 0.1); }
        .cyber-header-gradient { background: linear-gradient(135deg, #091225 0%, #031c38 100%); }
        .cyber-input { background: rgba(5, 8, 16, 0.7); border: 1px solid rgba(0, 195, 255, 0.2); transition: all 0.3s; color: #a0c4ff; }
        .cyber-input:focus { border-color: rgba(0, 195, 255, 1); box-shadow: 0 0 10px rgba(0, 195, 255, 0.4); }
        
        .cyber-button { background: linear-gradient(90deg, #02234f, #0747a1); position: relative; overflow: hidden; transition: all 0.3s; }
        .cyber-button::after { content: ''; position: absolute; top: -50%; left: -50%; width: 200%; height: 200%; background: linear-gradient(60deg, transparent 40%, rgba(0, 195, 255, 0.1) 50%, transparent 60%); transition: all 1s; transform: rotate(10deg); }
        .cyber-button:hover { background: linear-gradient(90deg, #0747a1, #0a5cd6); box-shadow: 0 0 15px rgba(0, 195, 255, 0.3); }
        .cyber-button:hover::after { left: 100%; }
        
        .glow-success { box-shadow: 0 0 15px rgba(34, 197, 94, 0.4); border-color: rgba(34, 197, 94, 0.2); }
        
        /* Custom date picker styling */
        ::-webkit-calendar-picker-indicator {
            filter: invert(60%) sepia(80%) saturate(500%) hue-rotate(180deg) brightness(100%) contrast(100%);
            cursor: pointer;
        }
    </style>
</head>
<body class="bg-black text-blue-200 min-h-screen flex items-center justify-center p-4">

    <div class="max-w-2xl w-full cyber-panel rounded-3xl overflow-hidden border">
        
        <div class="cyber-header-gradient p-10 text-center border-b border-cyan-900/30">
            <div class="inline-block p-4 bg-blue-900/40 rounded-full mb-4 border border-cyan-800/50" style="box-shadow: 0 0 15px rgba(0, 195, 255, 0.2);">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                </svg>
            </div>
            <h1 class="text-4xl font-bold text-white mb-2" style="text-shadow: 0 0 10px rgba(0,195,255,0.7);">מערכת איחוד נתוני מניות</h1>
            <p class="text-cyan-300 text-lg">איחוד נתונים מ-Yahoo ו-Google לתוך גיליון אקסל אחד</p>
        </div>

        <form id="stockForm" class="p-8 space-y-7">
            
            <div>
                <label class="block text-cyan-100 font-bold mb-2">סימולי מניות (מופרדים בפסיק):</label>
                <input type="text" id="tickers" placeholder="למשל: TSLA, AAPL, NVDA" required
                    class="w-full px-5 py-4 rounded-xl cyber-input outline-none text-xl font-mono">
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-7">
                <div>
                    <label class="block text-cyan-100 font-bold mb-2">תאריך התחלה:</label>
                    <input type="date" id="startDate" required
                        class="w-full px-4 py-3 rounded-xl cyber-input outline-none">
                </div>
                <div>
                    <label class="block text-cyan-100 font-bold mb-2">תאריך סיום:</label>
                    <input type="date" id="endDate" required
                        class="w-full px-4 py-3 rounded-xl cyber-input outline-none">
                </div>
            </div>

            <div>
                <label class="block text-cyan-100 font-bold mb-2">תדירות:</label>
                <select id="frequency" class="w-full px-4 py-3 rounded-xl cyber-input outline-none">
                    <option value="1d">יומי (Daily)</option>
                    <option value="1wk">שבועי (Weekly)</option>
                    <option value="1mo">חודשי (Monthly)</option>
                </select>
            </div>

            <button type="submit" id="submitBtn" 
                class="w-full text-white font-bold py-5 rounded-2xl shadow-xl cyber-button flex justify-center items-center text-2xl active:scale-95">
                <span id="btnText" style="text-shadow: 0 0 5px rgba(255,255,255,0.5);">הפק גיליון מאוחד</span>
            </button>
        </form>

        <div id="resultArea" class="hidden p-8 border-t border-cyan-900/30 bg-slate-950 text-center glow-success">
            <div class="bg-green-900/50 text-green-300 p-4 rounded-2xl mb-6 flex items-center justify-center gap-3 border border-green-700/50">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="font-bold text-lg">הבקשה נשלחה לשרת!</span>
            </div>
            <p class="text-cyan-200 mb-6 leading-relaxed text-lg">
                הגיליון החדש נוצר ברגעים אלו ב-Google Drive שלך.<br>
                חפש קובץ שמתחיל ב-<b>"Financial Export"</b>.
            </p>
            <a href="https://drive.google.com/drive/recent" target="_blank" 
                class="inline-block bg-blue-700 hover:bg-blue-600 text-white font-bold py-4 px-12 rounded-2xl shadow-lg transition-all text-xl" style="box-shadow: 0 0 15px rgba(30, 64, 175, 0.4);">
                פתח את ה-Drive לצפייה
            </a>
        </div>
    </div>

    <script>
        const WEB_APP_URL = 'https://script.google.com/macros/s/AKfycbxiQnCjIO4qLdeadQRdkkAjiRJxLOV2Px7c2gPCD4iCQ9HfVDIS8dH18ClQ_Lv3W_Mn/exec';

        document.getElementById('stockForm').addEventListener('submit', async (e) => {
            e.preventDefault();

            const submitBtn = document.getElementById('submitBtn');
            const btnText = document.getElementById('btnText');
            const resultArea = document.getElementById('resultArea');

            const payload = {
                tickers: document.getElementById('tickers').value.split(',').map(s => s.trim().toUpperCase()),
                startDate: document.getElementById('startDate').value,
                endDate: document.getElementById('endDate').value,
                frequency: document.getElementById('frequency').value
            };

            // Update UI for loading state
            submitBtn.disabled = true;
            btnText.innerText = "מתקשר עם השרת...";
            resultArea.classList.add('hidden');

            try {
                // Send data to the script
                await fetch(WEB_APP_URL, {
                    method: 'POST',
                    mode: 'no-cors', 
                    headers: { 'Content-Type': 'text/plain;charset=utf-8' },
                    body: JSON.stringify(payload)
                });

                // Assume success and show results area
                setTimeout(() => {
                    submitBtn.disabled = false;
                    btnText.innerText = "הפק גיליון מאוחד";
                    resultArea.classList.remove('hidden');
                    resultArea.scrollIntoView({ behavior: 'smooth' });
                }, 1500);

            } catch (error) {
                alert("אירעה שגיאה בתקשורת עם השרת.");
                submitBtn.disabled = false;
                btnText.innerText = "הפק גיליון מאוחד";
            }
        });

        // Set default dates
        const today = new Date().toISOString().split('T')[0];
        const lastMonth = new Date();
        lastMonth.setMonth(lastMonth.getMonth() - 1);
        document.getElementById('endDate').value = today;
        document.getElementById('startDate').value = lastMonth.toISOString().split('T')[0];
    </script>
</body>
</html>
